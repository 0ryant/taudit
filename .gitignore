/target
*.swp
*.swo
.DS_Store

# Local coordination scratch notes should not accumulate in the public repo.
Plans/*-ecosystem-note-*.md
docs/ECOSYSTEM_NOTE_FROM_*.md

# Internal collaboration and roadmap planning artifacts should stay local.
Plans/
BUILD_SHEET.md
.refs/

# Common local editor noise.
.idea/
.vscode/

# Stray test/build outputs
rust_out
CODE_REVIEW_FINDINGS_*.md

# Local AI session state — never committed.
MEMORY/
.claude/

# taudit operational state: backups and per-file scan baselines are
# machine-generated and should not be committed.  The .taudit/ directory
# itself IS intentionally tracked so that suppression configs and
# .taudit-suppressions.yml live in source control; only the generated
# sub-directories are excluded.
.taudit/backups/
.taudit/baselines/

# cargo-mutants output
mutants.out/
mutants.out.old/

# insta snapshot review files (do not commit these)
crates/*/tests/snapshots/*.snap.new

# cargo-fuzz build output (separate workspace per parser)
crates/*/fuzz/target/
