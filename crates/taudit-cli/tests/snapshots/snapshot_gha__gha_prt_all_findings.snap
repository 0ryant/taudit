  message: "[oidc_identity_in_untrusted_context] OIDC identity 'GITHUB_TOKEN' is reachable from untrusted trigger steps [check[0], check[1]]"
  recommendation:
    type: manual
    action: Move OIDC credential minting to a trusted-ref workflow or protect it with environment approvals and provider-side subject/audience conditions that exclude fork pull requests and untrusted merge requests.
  source: built-in
  fingerprint_anchor: identity=GITHUB_TOKEN
  confidence_scope: yaml_only
  runtime_preconditions:
