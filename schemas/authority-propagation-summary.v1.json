{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taudit.dev/schemas/authority-propagation-summary.v1.json",
  "title": "taudit authority propagation summary",
  "description": "Read-only aggregate over boundary-crossing propagation paths (same BFS as rule-engine authority_propagation). Additive 1.x; emitted by `taudit graph --format summary`. Does not replace graph JSON or verify policy.",
  "version": "1.1.0",
  "type": "object",
  "required": [
    "schema_version",
    "schema_uri",
    "source_file",
    "graph_completeness",
    "max_hops",
    "method",
    "totals",
    "top_sinks_by_path_count",
    "top_sources_by_path_count"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Semver of the emitted document. Loosened from a 1.0.0 const to a 1.x.y pattern in schema 1.1.0 so additive minor bumps remain valid under one schema file. Major bumps (2.0.0) get a new file.",
      "pattern": "^1\\.\\d+\\.\\d+$"
    },
    "schema_uri": {
      "type": "string",
      "format": "uri",
      "const": "https://taudit.dev/schemas/authority-propagation-summary.v1.json"
    },
    "source_file": { "type": "string" },
    "graph_completeness": {
      "type": "string",
      "enum": ["complete", "partial", "unknown"]
    },
    "completeness_gaps": {
      "type": "array",
      "items": { "type": "string" }
    },
    "completeness_gap_kinds": {
      "type": "array",
      "description": "Typed gap-kind classifications, parallel to `completeness_gaps` (same length, same order). Added in schema 1.1.0; absent on documents emitted by older builds and on Complete graphs.",
      "items": {
        "type": "string",
        "enum": ["expression", "structural", "opaque"]
      }
    },
    "worst_gap_kind": {
      "description": "Most severe `GapKind` present, by canonical severity ordering: opaque > structural > expression. Absent when the graph is Complete/Unknown or carries no typed gaps. Added in schema 1.1.0.",
      "type": ["string", "null"],
      "enum": ["expression", "structural", "opaque", null]
    },
    "max_hops": { "type": "integer", "minimum": 1 },
    "method": {
      "type": "string",
      "description": "Algorithm id; stable for consumers.",
      "const": "bfs_lower_trust_zone_sinks"
    },
    "totals": {
      "type": "object",
      "required": [
        "boundary_path_count",
        "distinct_authority_sources",
        "distinct_sinks"
      ],
      "additionalProperties": false,
      "properties": {
        "boundary_path_count": { "type": "integer", "minimum": 0 },
        "distinct_authority_sources": { "type": "integer", "minimum": 0 },
        "distinct_sinks": { "type": "integer", "minimum": 0 }
      }
    },
    "top_sinks_by_path_count": {
      "type": "array",
      "items": { "$ref": "#/$defs/PropagationNodeAgg" }
    },
    "top_sources_by_path_count": {
      "type": "array",
      "items": { "$ref": "#/$defs/PropagationNodeAgg" }
    }
  },
  "$defs": {
    "PropagationNodeAgg": {
      "type": "object",
      "required": ["node_id", "kind", "name", "trust_zone", "path_count"],
      "additionalProperties": false,
      "properties": {
        "node_id": { "type": "integer", "minimum": 0 },
        "kind": {
          "type": "string",
          "enum": ["step", "secret", "artifact", "identity", "image"]
        },
        "name": { "type": "string" },
        "trust_zone": {
          "type": "string",
          "enum": ["first_party", "third_party", "untrusted"]
        },
        "path_count": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
