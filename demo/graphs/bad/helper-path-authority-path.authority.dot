digraph taudit {
    rankdir=LR;
    node [fontname="Helvetica"];
    "n0" [label="GITHUB_TOKEN\nzone: FirstParty\nscope: broad\nperm: { contents: read, id-token: write }" shape=diamond color=green];
    "n1" [label="actions/checkout@v4\nzone: Untrusted" shape=cylinder color=red];
    "n2" [label="Checkout source\nzone: Untrusted" shape=ellipse color=red];
    "n3" [label="actions/setup-node@v4\nzone: Untrusted" shape=cylinder color=red];
    "n4" [label="Setup Node\nzone: Untrusted" shape=ellipse color=red];
    "n5" [label="Extend PATH before deploy\nzone: FirstParty" shape=ellipse color=green];
    "n6" [label="cloudflare/wrangler-action@v3\nzone: Untrusted" shape=cylinder color=red];
    "n7" [label="Publish docs\nzone: Untrusted" shape=ellipse color=red];
    "n8" [label="CLOUDFLARE_ACCOUNT_ID\nzone: FirstParty" shape=box color=green];
    "n9" [label="CLOUDFLARE_PAGES_API_TOKEN\nzone: FirstParty" shape=box color=green];
    "n2" -> "n1" [label="uses_image"];
    "n2" -> "n0" [label="has_access_to"];
    "n4" -> "n3" [label="uses_image"];
    "n4" -> "n0" [label="has_access_to"];
    "n5" -> "n0" [label="has_access_to"];
    "n7" -> "n6" [label="uses_image"];
    "n7" -> "n0" [label="has_access_to"];
    "n7" -> "n8" [label="has_access_to"];
    "n7" -> "n9" [label="has_access_to"];
}

