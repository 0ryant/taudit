{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taudit.dev/schemas/taudit-report.schema.json",
  "title": "taudit Report",
  "description": "JSON output from `taudit scan --format json`. Contains the authority graph, all findings, and a summary. Each finding carries a stable `fingerprint` (32 hex chars, SHA-256 truncated to 128 bits in v3) byte-identical to the value emitted in SARIF `partialFingerprints[primaryLocationLineHash]` and the CloudEvents extension attribute `tauditfindingfingerprint`. SIEMs key on the fingerprint to deduplicate findings across re-runs.",
  "type": "object",
  "required": ["schema_version", "graph", "findings", "summary"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Stable JSON report contract version"
    },
    "schema_uri": {
      "type": "string",
      "format": "uri",
      "description": "Canonical URI for the schema this document conforms to. Optional for backward compatibility with v1 consumers that pre-date this field."
    },
    "graph": { "$ref": "#/$defs/AuthorityGraph" },
    "findings": {
      "type": "array",
      "description": "Each entry is a `taudit Finding v1` object — see `https://taudit.dev/schemas/finding.v1.json` (also published in this repo at `schemas/finding.v1.json`). The local `#/$defs/Finding` mirrors that schema for inline validation; the standalone schema lets SIEM consumers validate finding payloads without loading the report wrapper.",
      "items": { "$ref": "#/$defs/Finding" }
    },
    "summary": { "$ref": "#/$defs/Summary" }
  },
  "$defs": {
    "AuthorityGraph": {
      "type": "object",
      "required": ["source", "nodes", "edges", "completeness"],
      "additionalProperties": false,
      "properties": {
        "source": { "$ref": "#/$defs/PipelineSource" },
        "nodes": {
          "type": "array",
          "items": { "$ref": "#/$defs/Node" }
        },
        "edges": {
          "type": "array",
          "items": { "$ref": "#/$defs/Edge" }
        },
        "completeness": { "$ref": "#/$defs/AuthorityCompleteness" },
        "completeness_gaps": {
          "type": "array",
          "items": { "type": "string" }
        },
        "completeness_gap_kinds": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["expression", "structural", "opaque"]
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "AuthorityCompleteness": {
      "type": "string",
      "enum": ["complete", "partial", "unknown"]
    },
    "PipelineSource": {
      "type": "object",
      "required": ["file"],
      "additionalProperties": false,
      "properties": {
        "file": { "type": "string" },
        "repo": { "type": "string" },
        "git_ref": { "type": "string" }
      }
    },
    "Node": {
      "type": "object",
      "required": ["id", "kind", "name", "trust_zone", "metadata"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "integer", "minimum": 0 },
        "kind": {
          "type": "string",
          "enum": ["step", "secret", "artifact", "identity", "image"]
        },
        "name": { "type": "string" },
        "trust_zone": {
          "type": "string",
          "enum": ["first_party", "third_party", "untrusted"]
        },
        "metadata": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "Edge": {
      "type": "object",
      "required": ["id", "from", "to", "kind"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "integer", "minimum": 0 },
        "from": { "type": "integer", "minimum": 0 },
        "to": { "type": "integer", "minimum": 0 },
        "kind": {
          "type": "string",
          "enum": ["has_access_to", "produces", "consumes", "uses_image", "delegates_to", "persists_to"]
        },
        "authority_summary": { "$ref": "#/$defs/AuthorityEdgeSummary" }
      }
    },
    "AuthorityEdgeSummary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "trust_zone": { "type": "string" },
        "identity_scope": { "type": "string" },
        "permissions_summary": { "type": "string" }
      }
    },
    "Finding": {
      "type": "object",
      "required": ["severity", "category", "nodes_involved", "message", "recommendation"],
      "additionalProperties": false,
      "properties": {
        "severity": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low", "info"]
        },
        "category": {
          "type": "string",
          "enum": [
            "add_spn_with_inline_script",
            "artifact_boundary_crossing",
            "authority_cycle",
            "authority_propagation",
            "cache_key_crosses_trust_boundary",
            "checkout_self_pr_exposure",
            "child_pipeline_trigger_inherits_authority",
            "ci_job_token_to_external_api",
            "ci_token_triggers_downstream_with_variable_passthrough",
            "cross_workflow_authority_chain",
            "dind_service_grants_host_authority",
            "dotenv_artifact_flows_to_privileged_deployment",
            "egress_blindspot",
            "floating_image",
            "gh_cli_with_default_token_escalating",
        "gha_script_injection_to_privileged_shell",
        "gha_workflow_run_artifact_poisoning_to_privileged_consumer",
        "gha_remote_script_in_authority_job",
        "gha_pat_remote_url_write",
        "gha_issue_comment_command_to_write_token",
        "gha_pr_build_pushes_publishable_image",
        "gha_manual_dispatch_ref_to_privileged_checkout",
            "gha_action_minted_secret_to_helper",
            "gha_action_token_env_before_bare_download_helper",
            "gha_azure_companion_helper_authority",
            "gha_changesets_publish_command_with_authority",
            "gha_composite_bare_helper_after_path_install_with_secret_env",
            "gha_composite_entrypoint_path_shadow_with_secret_env",
            "gha_create_pr_git_token_path_handoff",
            "gha_datadog_test_visibility_installer_authority",
            "gha_docker_buildx_authority_path_handoff",
            "gha_docker_setup_qemu_privileged_docker_helper",
            "gha_google_deploy_gcloud_credential_path",
            "gha_helper_path_sensitive_argv",
            "gha_helper_path_sensitive_env",
            "gha_helper_path_sensitive_stdin",
            "gha_helper_untrusted_path_resolution",
            "gha_import_gpg_private_key_helper_path",
            "gha_kubernetes_helper_kubeconfig_authority",
            "gha_macos_codesign_cert_security_path",
            "gha_manifest_cargo_build_rs_pull_request_with_token",
            "gha_manifest_makefile_with_pr_trigger_and_secrets",
            "gha_manifest_npm_lifecycle_hook_pr_trigger_with_token",
            "gha_manifest_python_m_build_with_pr_credentials",
            "gha_manifest_submodules_recursive_with_pr_authority",
            "gha_pages_deploy_token_url_to_git_helper",
            "gha_post_ambient_env_cleanup_path",
            "gha_post_action_input_retarget_to_cache_save",
            "gha_pulumi_path_resolved_cli_with_authority",
            "gha_pypi_publish_oidc_after_path_mutation",
            "gha_rubygems_release_git_token_and_oidc_helper",
            "gha_secret_output_after_helper_login",
            "gha_setup_go_cache_helper_path_handoff",
            "gha_setup_node_cache_helper_path_handoff",
            "gha_setup_python_cache_helper_path_handoff",
            "gha_setup_python_pip_install_authority_env",
            "gha_ssh_agent_private_key_to_path_helper",
            "gha_tool_installer_then_shell_helper_authority",
            "gha_toolcache_absolute_path_downgrade",
            "gha_terraform_wrapper_sensitive_output",
            "gha_workflow_shell_authority_concentration",
            "gha_crossrepo_secrets_inherit_unreviewed_callee",
            "gha_crossrepo_workflow_call_floating_ref_cascade",
            "gitlab_deploy_job_missing_protected_branch_only",
            "homoglyph_in_action_ref",
            "id_token_audience_overscoped",
            "interactive_debug_action_in_authority_workflow",
            "keyvault_secret_to_plaintext",
            "later_secret_materialized_after_path_mutation",
            "long_lived_credential",
            "long_lived_secret_without_oidc_recommendation",
            "manual_dispatch_input_to_url_or_command",
            "missing_audit_trail",
            "no_workflow_level_permissions_block",
            "over_privileged_identity",
            "parameter_interpolation_into_shell",
            "pat_embedded_in_git_remote_url",
            "persisted_credential",
            "pr_build_pushes_image_with_floating_credentials",
            "pr_specific_cache_key_in_default_branch_consumer",
            "pr_trigger_with_floating_action_ref",
            "prod_deploy_job_no_environment_gate",
            "pull_request_workflow_inconsistent_fork_check",
            "risky_trigger_with_authority",
            "runtime_script_fetched_from_floating_url",
            "script_injection_via_untrusted_context",
            "secret_materialised_to_workspace_file",
            "secret_to_inline_script_env_export",
            "secret_via_env_gate_to_untrusted_consumer",
            "secrets_inherit_overscoped_passthrough",
            "security_job_silently_skipped",
            "self_hosted_pool_pr_hijack",
            "self_mutating_pipeline",
            "sensitive_value_in_job_output",
            "service_connection_scope_mismatch",
            "setvariable_issecret_false",
            "shared_self_hosted_pool_no_isolation",
            "short_lived_sas_in_command_line",
            "template_extends_unpinned_branch",
            "template_repo_ref_is_feature_branch",
            "terraform_auto_approve_in_prod",
            "terraform_output_via_setvariable_shell_expansion",
            "trigger_context_mismatch",
            "unpinned_action",
            "unpinned_include_remote_or_branch_ref",
            "unsafe_pr_artifact_in_workflow_run_consumer",
            "untrusted_api_response_to_env_sink",
            "untrusted_ci_var_in_shell_interpolation",
            "untrusted_with_authority",
            "uplift_without_attestation",
            "variable_group_in_pr_job",
            "vm_remote_exec_via_pipeline_secret"
          ]
        },
        "path": {
          "oneOf": [
            { "$ref": "#/$defs/PropagationPath" },
            { "type": "null" }
          ]
        },
        "nodes_involved": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 }
        },
        "message": { "type": "string" },
        "recommendation": { "$ref": "#/$defs/Recommendation" },
        "rule_id": {
          "type": "string",
          "minLength": 1,
          "description": "Snake_case rule identifier — custom-rule id when the finding came from a YAML rule with a `[id] ...` message prefix, otherwise the snake_case form of `category`. Byte-identical to SARIF `result.ruleId` and CloudEvents `taudit.rule_id`. JSON consumers filter and group by this field. Optional in v1 for backward-compat; always emitted by current taudit."
        },
        "source": {
          "description": "Provenance of the finding. `\"built-in\"` (string) means the finding was emitted by a rule shipped in the taudit binary. An object `{\"custom\": {\"source_file\": \"<path>\"}}` means the finding came from a custom invariant YAML loaded via `--invariants-dir`; the path is the file the rule was loaded from. Optional in v1 for backward-compat; always emitted by current taudit. SIEMs / triage tooling should treat any non-`built-in` source as untrusted-by-default and surface the originating path in alerts.",
          "oneOf": [
            { "type": "string", "enum": ["built-in"] },
            {
              "type": "object",
              "required": ["custom"],
              "additionalProperties": false,
              "properties": {
                "custom": {
                  "type": "object",
                  "required": ["source_file"],
                  "additionalProperties": false,
                  "properties": {
                    "source_file": { "type": "string" }
                  }
                }
              }
            }
          ]
        },
        "fingerprint": {
          "type": "string",
          "pattern": "^[0-9a-f]{32}$",
          "description": "Stable cross-run identifier for the finding (32 hex chars, v3 algorithm: SHA-256 truncated to 128 bits). Byte-identical to the value emitted in SARIF `partialFingerprints[primaryLocationLineHash]` and CloudEvents `tauditfindingfingerprint`. Use for SIEM dedup and suppression. Widened from 16 hex (64-bit) in v1.1.0-beta.3 to close a birthday-collision attack. Optional in v1 for backward-compat; always emitted by current taudit. See docs/finding-fingerprint.md."
        },
        "finding_group_id": {
          "type": "string",
          "format": "uuid",
          "description": "Stable UUID v5 derived from the finding fingerprint. Two findings with the same fingerprint share a group id, so SIEMs can collapse N hops against the same authority root into a single advisory. Optional. See docs/finding-output-enhancements.md."
        },
        "time_to_fix": {
          "type": "string",
          "enum": ["trivial", "small", "medium", "large"],
          "description": "Coarse remediation effort. trivial = ~5 min flag flip; small = ~1 hr step refactor; medium = ~1 day job restructure; large = ~1 week+ ops policy change. Optional; populated per-rule. Triage dashboards sort by `severity * time_to_fix` to surface highest-ROI fixes."
        },
        "compensating_controls": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Human-readable list of detected compensating controls that downgraded this finding's severity. Empty when no downgrade applied. Populated by compensating-control detectors (e.g. fork check present, environment gate present, OIDC token used)."
        },
        "suppressed": {
          "type": "boolean",
          "description": "True when a `.taudit-suppressions.yml` waiver matched and the configured mode is `suppress` (vs. `downgrade`). The finding is still emitted so audit trail is preserved; consumers may filter on this field."
        },
        "original_severity": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low", "info"],
          "description": "Pre-downgrade severity. Populated whenever a suppression entry OR a compensating control downgraded `severity`. Absent means the current severity is the rule-emitted value."
        },
        "suppression_reason": {
          "type": "string",
          "description": "Operator-supplied justification from the matching `.taudit-suppressions.yml` entry. Absent when no suppression applies."
        },
        "confidence_scope": {
          "type": "string",
          "enum": ["yaml_only"],
          "description": "Evidence boundary for the finding. `yaml_only` means taudit proved the static authority shape in the scanned YAML artifact; runtime/provider settings may still affect exploitability."
        },
        "runtime_preconditions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Runtime or provider-side assumptions to verify before treating the static finding as live exploitability."
        },
        "portal_control_dependency": {
          "type": "boolean",
          "description": "True when exploitability materially depends on provider-side controls outside YAML, such as Azure DevOps service-connection authorization or GitHub repository settings."
        },
        "authority_kinds": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Coarse authority types involved in the finding."
        },
        "attacker_surface_kinds": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Coarse attacker-influenced surfaces involved in the finding."
        },
        "template_resolution_strength": {
          "type": "string",
          "enum": ["resolved", "partial", "opaque", "not_applicable"],
          "description": "Resolution strength for reusable workflow/template delegation findings."
        },
        "cve_relationship": {
          "type": "string",
          "enum": ["same_primitive", "same_authority_shape", "analogue_only", "not_applicable"],
          "description": "Relationship between this finding and any cited public CVE/advisory class."
        }
      }
    },
    "PropagationPath": {
      "type": "object",
      "required": ["source", "sink", "edges", "crossed_boundary"],
      "additionalProperties": false,
      "properties": {
        "source": { "type": "integer", "minimum": 0 },
        "sink": { "type": "integer", "minimum": 0 },
        "edges": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 }
        },
        "crossed_boundary": { "type": "boolean" },
        "boundary_crossing": {
          "type": "array",
          "prefixItems": [
            { "type": "string", "enum": ["first_party", "third_party", "untrusted"] },
            { "type": "string", "enum": ["first_party", "third_party", "untrusted"] }
          ],
          "items": false,
          "minItems": 2,
          "maxItems": 2
        }
      }
    },
    "Recommendation": {
      "description": "Internally-tagged union. The 'type' field selects the variant; remaining fields are variant-specific.",
      "type": "object",
      "required": ["type"],
      "oneOf": [
        {
          "properties": {
            "type": { "const": "tsafe_remediation" },
            "command": { "type": "string" },
            "explanation": { "type": "string" }
          },
          "required": ["type", "command", "explanation"]
        },
        {
          "properties": {
            "type": { "const": "cellos_remediation" },
            "reason": { "type": "string" },
            "spec_hint": { "type": "string" }
          },
          "required": ["type", "reason", "spec_hint"]
        },
        {
          "properties": {
            "type": { "const": "pin_action" },
            "current": { "type": "string" },
            "pinned": { "type": "string" }
          },
          "required": ["type", "current", "pinned"]
        },
        {
          "properties": {
            "type": { "const": "reduce_permissions" },
            "current": { "type": "string" },
            "minimum": { "type": "string" }
          },
          "required": ["type", "current", "minimum"]
        },
        {
          "properties": {
            "type": { "const": "federate_identity" },
            "static_secret": { "type": "string" },
            "oidc_provider": { "type": "string" }
          },
          "required": ["type", "static_secret", "oidc_provider"]
        },
        {
          "properties": {
            "type": { "const": "manual" },
            "action": { "type": "string" }
          },
          "required": ["type", "action"]
        }
      ]
    },
    "Summary": {
      "type": "object",
      "required": ["total_findings", "critical", "high", "medium", "low", "info", "total_nodes", "total_edges", "completeness"],
      "additionalProperties": false,
      "properties": {
        "total_findings": { "type": "integer", "minimum": 0 },
        "critical": { "type": "integer", "minimum": 0 },
        "high": { "type": "integer", "minimum": 0 },
        "medium": { "type": "integer", "minimum": 0 },
        "low": { "type": "integer", "minimum": 0 },
        "info": { "type": "integer", "minimum": 0 },
        "total_nodes": { "type": "integer", "minimum": 0 },
        "total_edges": { "type": "integer", "minimum": 0 },
        "completeness": { "$ref": "#/$defs/AuthorityCompleteness" },
        "completeness_gaps": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "reason"],
            "properties": {
              "kind": {
                "type": "string",
                "enum": ["expression", "structural", "opaque"]
              },
              "reason": { "type": "string" }
            }
          }
        },
        "graph_risk_summary": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "authority_roots": { "type": "integer", "minimum": 0 },
            "untrusted_sinks": { "type": "integer", "minimum": 0 },
            "mutable_refs": { "type": "integer", "minimum": 0 },
            "publication_adjacent_sinks": { "type": "integer", "minimum": 0 },
            "delegation_hops": { "type": "integer", "minimum": 0 },
            "protected_resource_categories": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
