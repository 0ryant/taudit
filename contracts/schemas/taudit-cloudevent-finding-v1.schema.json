{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taudit.dev/schemas/cloudevent-finding-v1.json",
  "title": "taudit CloudEvent Finding v1",
  "description": "CloudEvents 1.0 envelope wrapping a single taudit finding. One event per JSONL line.",
  "type": "object",
  "required": [
    "specversion",
    "id",
    "source",
    "type",
    "correlationid",
    "provenancerepo",
    "provenanceproducer",
    "provenanceversion",
    "provenancekind"
  ],
  "properties": {
    "specversion": {
      "type": "string",
      "const": "1.0"
    },
    "id": {
      "type": "string",
      "description": "UUID v4 unique per event"
    },
    "source": {
      "type": "string",
      "const": "taudit",
      "description": "Always 'taudit'"
    },
    "type": {
      "type": "string",
      "description": "io.taudit.finding.{category}",
      "pattern": "^io\\.taudit\\.finding\\.[a-z_]+$"
    },
    "subject": {
      "type": "string",
      "description": "Pipeline file path that was scanned"
    },
    "datacontenttype": {
      "type": "string",
      "const": "application/json"
    },
    "time": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 timestamp"
    },
    "tauditcompleteness": {
      "type": "string",
      "enum": ["complete", "partial", "unknown"],
      "description": "Authority graph completeness extension attribute"
    },
    "tauditfindingfingerprint": {
      "type": "string",
      "pattern": "^[0-9a-f]{16}$",
      "description": "Stable cross-run finding fingerprint (16 hex chars, SHA-256-derived). Byte-identical to SARIF `partialFingerprints[primaryLocationLineHash]` and JSON `findings[].fingerprint`. Use for SIEM dedup. Optional in v1 for backward-compat; always emitted by current taudit. See docs/finding-fingerprint.md."
    },
    "tauditplatform": {
      "type": "string",
      "enum": ["ado", "gha", "gitlab"],
      "description": "CI/CD platform of the underlying pipeline. SIEM correlation rules use this to route events to per-platform remediation runbooks without re-parsing the `subject` (file path). Source: `graph.metadata[\"platform\"]`, populated from the resolved `Platform` variant during scan. Optional in v1 for backward-compat; always emitted by current taudit when the parser stamped the metadata key."
    },
    "correlationid": {
      "type": "string",
      "minLength": 1,
      "description": "Shared correlation key for all events emitted from a single taudit scan"
    },
    "provenancerepo": {
      "type": "string",
      "const": "taudit",
      "description": "Repository that emitted the event"
    },
    "provenanceproducer": {
      "type": "string",
      "const": "taudit-sink-cloudevents",
      "description": "Subsystem that produced the CloudEvent envelope"
    },
    "provenanceversion": {
      "type": "string",
      "description": "Producer version or schema version"
    },
    "provenancekind": {
      "type": "string",
      "const": "finding",
      "description": "High-level evidence kind for taudit finding events"
    },
    "data": {
      "type": "object",
      "description": "The full Finding object",
      "required": ["severity", "category", "message", "recommendation"],
      "properties": {
        "severity": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low", "info"]
        },
        "category": {
          "type": "string",
          "enum": [
            "authority_propagation",
            "over_privileged_identity",
            "unpinned_action",
            "untrusted_with_authority",
            "artifact_boundary_crossing",
            "floating_image",
            "long_lived_credential",
            "persisted_credential",
            "egress_blindspot",
            "missing_audit_trail"
          ]
        },
        "path": {
          "description": "Propagation path evidence, if applicable"
        },
        "nodes_involved": {
          "type": "array",
          "items": { "type": "integer" }
        },
        "message": {
          "type": "string"
        },
        "recommendation": {
          "type": "object",
          "description": "Typed recommendation with routing info"
        }
      }
    }
  }
}
