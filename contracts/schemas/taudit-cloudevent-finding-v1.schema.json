{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taudit.dev/schemas/cloudevent-finding-v1.json",
  "title": "taudit CloudEvent Finding v1",
  "description": "CloudEvents 1.0 envelope wrapping a single taudit finding. One event per JSONL line.",
  "type": "object",
  "required": [
    "specversion",
    "id",
    "source",
    "type",
    "correlationid",
    "provenancerepo",
    "provenanceproducer",
    "provenanceversion",
    "provenancekind"
  ],
  "properties": {
    "specversion": {
      "type": "string",
      "const": "1.0"
    },
    "id": {
      "type": "string",
      "description": "UUID v4 unique per event"
    },
    "source": {
      "type": "string",
      "const": "taudit",
      "description": "Always 'taudit'"
    },
    "type": {
      "type": "string",
      "description": "io.taudit.finding.{category}",
      "pattern": "^io\\.taudit\\.finding\\.[a-z_]+$"
    },
    "subject": {
      "type": "string",
      "description": "Pipeline file path that was scanned"
    },
    "datacontenttype": {
      "type": "string",
      "const": "application/json"
    },
    "time": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 timestamp"
    },
    "tauditcompleteness": {
      "type": "string",
      "enum": ["complete", "partial", "unknown"],
      "description": "Authority graph completeness extension attribute"
    },
    "tauditfindingfingerprint": {
      "type": "string",
      "pattern": "^[0-9a-f]{32}$",
      "description": "Stable cross-run finding fingerprint (32 hex chars, v3 algorithm: SHA-256 truncated to 128 bits). Byte-identical to SARIF `partialFingerprints[primaryLocationLineHash]` and JSON `findings[].fingerprint`. Use for SIEM dedup. Widened from 16 hex (64-bit) in v1.1.0-beta.3 to close a birthday-collision attack against `.taudit-suppressions.yml`. Optional in v1 for backward-compat; always emitted by current taudit. See docs/finding-fingerprint.md."
    },
    "tauditruleid": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Canonical snake_case rule id. Byte-identical to JSON `findings[].rule_id` and SARIF `result.ruleId`. The `type` attribute stays scoped to the `FindingCategory` for routing stability; this attribute exposes the exact rule that fired so consumers can filter / suppress at rule granularity (custom YAML rules surface their `[id]` prefix here). Optional in v1 for backward-compat; always emitted by current taudit."
    },
    "tauditplatform": {
      "type": "string",
      "enum": ["ado", "gha", "gitlab"],
      "description": "CI/CD platform of the underlying pipeline. SIEM correlation rules use this to route events to per-platform remediation runbooks without re-parsing the `subject` (file path). Source: `graph.metadata[\"platform\"]`, populated from the resolved `Platform` variant during scan. Optional in v1 for backward-compat; always emitted by current taudit when the parser stamped the metadata key."
    },
    "tauditfindinggroup": {
      "type": "string",
      "format": "uuid",
      "description": "Stable UUID v5 derived from the fingerprint. Two findings with the same fingerprint share a group id; SIEMs collapse N hops against one authority root into a single advisory by `SELECT DISTINCT ON (tauditfindinggroup)`. Optional in v1 for backward-compat. See docs/finding-output-enhancements.md."
    },
    "correlationid": {
      "type": "string",
      "minLength": 1,
      "description": "Shared correlation key for all events emitted from a single taudit scan"
    },
    "provenancerepo": {
      "type": "string",
      "const": "taudit",
      "description": "Repository that emitted the event"
    },
    "provenanceproducer": {
      "type": "string",
      "const": "taudit-sink-cloudevents",
      "description": "Subsystem that produced the CloudEvent envelope"
    },
    "provenanceversion": {
      "type": "string",
      "description": "Producer version or schema version"
    },
    "provenancekind": {
      "type": "string",
      "const": "finding",
      "description": "High-level evidence kind for taudit finding events"
    },
    "data": {
      "type": "object",
      "description": "The full Finding object",
      "required": ["severity", "category", "message", "recommendation"],
      "properties": {
        "severity": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low", "info"]
        },
        "category": {
          "type": "string",
          "enum": [
            "add_spn_with_inline_script",
            "artifact_boundary_crossing",
            "authority_cycle",
            "authority_propagation",
            "cache_key_crosses_trust_boundary",
            "checkout_self_pr_exposure",
            "child_pipeline_trigger_inherits_authority",
            "ci_job_token_to_external_api",
            "ci_token_triggers_downstream_with_variable_passthrough",
            "cross_workflow_authority_chain",
            "dind_service_grants_host_authority",
            "dotenv_artifact_flows_to_privileged_deployment",
            "egress_blindspot",
            "floating_image",
            "gh_cli_with_default_token_escalating",
            "gitlab_deploy_job_missing_protected_branch_only",
            "homoglyph_in_action_ref",
            "id_token_audience_overscoped",
            "interactive_debug_action_in_authority_workflow",
            "keyvault_secret_to_plaintext",
            "long_lived_credential",
            "long_lived_secret_without_oidc_recommendation",
            "manual_dispatch_input_to_url_or_command",
            "missing_audit_trail",
            "no_workflow_level_permissions_block",
            "over_privileged_identity",
            "parameter_interpolation_into_shell",
            "pat_embedded_in_git_remote_url",
            "persisted_credential",
            "pr_build_pushes_image_with_floating_credentials",
            "pr_specific_cache_key_in_default_branch_consumer",
            "pr_trigger_with_floating_action_ref",
            "prod_deploy_job_no_environment_gate",
            "pull_request_workflow_inconsistent_fork_check",
            "risky_trigger_with_authority",
            "runtime_script_fetched_from_floating_url",
            "script_injection_via_untrusted_context",
            "secret_materialised_to_workspace_file",
            "secret_to_inline_script_env_export",
            "secret_via_env_gate_to_untrusted_consumer",
            "secrets_inherit_overscoped_passthrough",
            "security_job_silently_skipped",
            "self_hosted_pool_pr_hijack",
            "self_mutating_pipeline",
            "sensitive_value_in_job_output",
            "service_connection_scope_mismatch",
            "setvariable_issecret_false",
            "shared_self_hosted_pool_no_isolation",
            "short_lived_sas_in_command_line",
            "template_extends_unpinned_branch",
            "template_repo_ref_is_feature_branch",
            "terraform_auto_approve_in_prod",
            "terraform_output_via_setvariable_shell_expansion",
            "trigger_context_mismatch",
            "unpinned_action",
            "unpinned_include_remote_or_branch_ref",
            "unsafe_pr_artifact_in_workflow_run_consumer",
            "untrusted_api_response_to_env_sink",
            "untrusted_ci_var_in_shell_interpolation",
            "untrusted_with_authority",
            "uplift_without_attestation",
            "variable_group_in_pr_job",
            "vm_remote_exec_via_pipeline_secret"
          ]
        },
        "path": {
          "description": "Propagation path evidence, if applicable"
        },
        "nodes_involved": {
          "type": "array",
          "items": { "type": "integer" }
        },
        "message": {
          "type": "string"
        },
        "recommendation": {
          "type": "object",
          "description": "Typed recommendation with routing info"
        }
      }
    }
  }
}
