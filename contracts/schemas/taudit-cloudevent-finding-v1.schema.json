{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taudit.dev/schemas/cloudevent-finding-v1.json",
  "title": "taudit CloudEvent Finding v1",
  "description": "CloudEvents 1.0 envelope wrapping a single taudit finding. One event per JSONL line.",
  "type": "object",
  "required": [
    "specversion",
    "id",
    "source",
    "type",
    "correlationid",
    "provenancerepo",
    "provenanceproducer",
    "provenanceversion",
    "provenancekind"
  ],
  "properties": {
    "specversion": {
      "type": "string",
      "const": "1.0"
    },
    "id": {
      "type": "string",
      "description": "UUID v4 unique per event"
    },
    "source": {
      "type": "string",
      "const": "taudit",
      "description": "Always 'taudit'"
    },
    "type": {
      "type": "string",
      "description": "io.taudit.finding.{category}",
      "pattern": "^io\\.taudit\\.finding\\.[a-z_]+$"
    },
    "subject": {
      "type": "string",
      "description": "Pipeline file path that was scanned"
    },
    "datacontenttype": {
      "type": "string",
      "const": "application/json"
    },
    "time": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 timestamp"
    },
    "tauditcompleteness": {
      "type": "string",
      "enum": ["complete", "partial", "unknown"],
      "description": "Authority graph completeness extension attribute"
    },
    "tauditfindingfingerprint": {
      "type": "string",
      "pattern": "^[0-9a-f]{32}$",
      "description": "Stable cross-run finding fingerprint (32 hex chars, v3 algorithm: SHA-256 truncated to 128 bits). Byte-identical to SARIF `partialFingerprints[primaryLocationLineHash]` and JSON `findings[].fingerprint`. Use for SIEM dedup. Widened from 16 hex (64-bit) in v1.1.0-beta.3 to close a birthday-collision attack against `.taudit-suppressions.yml`. Optional in v1 for backward-compat; always emitted by current taudit. See docs/finding-fingerprint.md."
    },
    "tauditsuppressionkey": {
      "type": "string",
      "pattern": "^sk1_[0-9a-f]{32}$",
      "description": "Operator-stable waiver key (`sk1_` plus 32 hex chars). Coarser than `tauditfindingfingerprint`: it excludes ordered involved-node names so a reviewed `.taudit-suppressions.yml` waiver can survive unrelated surrounding workflow edits. Byte-identical to JSON `findings[].suppression_key` and SARIF `properties.suppressionKey`."
    },
    "tauditruleid": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Canonical snake_case rule id. Byte-identical to JSON `findings[].rule_id` and SARIF `result.ruleId`. The `type` attribute stays scoped to the `FindingCategory` for routing stability; this attribute exposes the exact rule that fired so consumers can filter / suppress at rule granularity (custom YAML rules surface their `[id]` prefix here). Optional in v1 for backward-compat; always emitted by current taudit."
    },
    "tauditplatform": {
      "type": "string",
      "enum": ["ado", "bb", "bitbucket", "gha", "gitlab"],
      "description": "CI/CD platform of the underlying pipeline. SIEM correlation rules use this to route events to per-platform remediation runbooks without re-parsing the `subject` (file path). Source: `graph.metadata[\"platform\"]`, populated from the resolved `Platform` variant during scan. Optional in v1 for backward-compat; always emitted by current taudit when the parser stamped the metadata key."
    },
    "tauditfindinggroup": {
      "type": "string",
      "format": "uuid",
      "description": "Stable UUID v5 derived from the fingerprint. Two findings with the same fingerprint share a group id; SIEMs collapse N hops against one authority root into a single advisory by `SELECT DISTINCT ON (tauditfindinggroup)`. Optional in v1 for backward-compat. See docs/finding-output-enhancements.md."
    },
    "correlationid": {
      "type": "string",
      "minLength": 1,
      "description": "Shared correlation key for all events emitted from a single taudit scan"
    },
    "tauditpipelineid": {
      "type": "string",
      "pattern": "^urn:taudit:pipeline:sha256:[0-9a-f]{64}$",
      "description": "Stable pipeline identifier URN. Preferred source is parser/CLI-stamped `graph.metadata[\"pipeline_content_hash\"]` (`sha256:<64-hex>`); sink falls back to deterministic derivation from graph identity material when absent. Optional in v1 for backward-compat; always emitted by current taudit."
    },
    "tauditscanrunid": {
      "type": "string",
      "minLength": 1,
      "description": "Per-invocation scan run identifier, shared by all events from a single sink `emit` call. Distinct from `correlationid` (operator-flow join key, which may intentionally span multiple scans). Optional in v1 for backward-compat; always emitted by current taudit."
    },
    "provenancerepo": {
      "type": "string",
      "const": "taudit",
      "description": "Repository that emitted the event"
    },
    "provenanceproducer": {
      "type": "string",
      "const": "taudit-sink-cloudevents",
      "description": "Subsystem that produced the CloudEvent envelope"
    },
    "provenanceversion": {
      "type": "string",
      "description": "Producer version or schema version"
    },
    "provenancekind": {
      "type": "string",
      "const": "finding",
      "description": "High-level evidence kind for taudit finding events"
    },
    "data": {
      "type": "object",
      "description": "The full Finding object",
      "required": ["severity", "category", "message", "recommendation"],
      "properties": {
        "severity": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low", "info"]
        },
        "category": {
          "type": "string",
          "enum": [
            "add_spn_with_inline_script",
            "artifact_boundary_crossing",
            "authority_cycle",
            "authority_propagation",
            "cache_key_crosses_trust_boundary",
            "checkout_self_pr_exposure",
            "child_pipeline_trigger_inherits_authority",
            "ci_job_token_to_external_api",
            "ci_token_triggers_downstream_with_variable_passthrough",
            "cross_workflow_authority_chain",
            "dind_service_grants_host_authority",
            "dotenv_artifact_flows_to_privileged_deployment",
            "egress_blindspot",
            "floating_image",
            "gh_cli_with_default_token_escalating",
            "gha_action_minted_secret_to_helper",
            "gha_action_token_env_before_bare_download_helper",
            "gha_api_workflow_run_artifact_to_autonomous_agent_to_git_push",
            "gha_attestation_config_driven_gate_from_workspace_file",
            "gha_attestation_subject_digest_from_step_output_unverified",
            "gha_attestation_subject_path_workspace_glob_with_pr_trigger",
            "gha_azure_companion_helper_authority",
            "gha_changesets_publish_command_with_authority",
            "gha_composite_bare_helper_after_path_install_with_secret_env",
            "gha_composite_entrypoint_path_shadow_with_secret_env",
            "gha_container_image_attacker_influenced_with_secret_env",
            "gha_create_pr_git_token_path_handoff",
            "gha_crossrepo_secrets_inherit_unreviewed_callee",
            "gha_crossrepo_workflow_call_floating_ref_cascade",
            "gha_datadog_test_visibility_installer_authority",
            "gha_docker_buildx_authority_path_handoff",
            "gha_docker_setup_qemu_privileged_docker_helper",
            "gha_env_credential_helper_config_redirect_before_authority",
            "gha_env_dyld_or_ld_library_path_before_credential_helper",
            "gha_env_node_options_code_injection_before_node_authority",
            "gha_floating_remote_script_before_publish_sink",
            "gha_google_deploy_gcloud_credential_path",
            "gha_helper_path_sensitive_argv",
            "gha_helper_path_sensitive_env",
            "gha_helper_path_sensitive_stdin",
            "gha_helper_untrusted_path_resolution",
            "gha_import_gpg_private_key_helper_path",
            "gha_issue_comment_command_to_write_token",
            "gha_kubernetes_helper_kubeconfig_authority",
            "gha_macos_codesign_cert_security_path",
            "gha_manifest_cargo_build_rs_pull_request_with_token",
            "gha_manifest_makefile_with_pr_trigger_and_secrets",
            "gha_manifest_npm_lifecycle_hook_pr_trigger_with_token",
            "gha_manifest_python_m_build_with_pr_credentials",
            "gha_manifest_submodules_recursive_with_pr_authority",
            "gha_manual_dispatch_ref_to_privileged_checkout",
            "gha_pages_deploy_token_url_to_git_helper",
            "gha_pat_remote_url_write",
            "gha_post_action_input_retarget_to_cache_save",
            "gha_post_ambient_env_cleanup_path",
            "gha_pr_build_pushes_publishable_image",
            "gha_pulumi_path_resolved_cli_with_authority",
            "gha_pypi_publish_oidc_after_path_mutation",
            "gha_remote_script_in_authority_job",
            "gha_rubygems_release_git_token_and_oidc_helper",
            "gha_script_injection_to_privileged_shell",
            "gha_secret_output_after_helper_login",
            "gha_setup_go_cache_helper_path_handoff",
            "gha_setup_node_cache_helper_path_handoff",
            "gha_setup_python_cache_helper_path_handoff",
            "gha_setup_python_pip_install_authority_env",
            "gha_ssh_agent_private_key_to_path_helper",
            "gha_telemetry_autonomous_agent_input_from_untrusted_event",
            "gha_telemetry_debug_flag_with_secret_env",
            "gha_telemetry_pr_or_issue_text_to_external_sink",
            "gha_terraform_wrapper_sensitive_output",
            "gha_token_remote_url_with_trace_or_process_exposure",
            "gha_tool_installer_then_shell_helper_authority",
            "gha_toolcache_absolute_path_downgrade",
            "gha_workflow_call_container_image_input_secrets_inherit",
            "gha_workflow_call_runner_label_input_privilege_escalation",
            "gha_workflow_run_artifact_metadata_to_privileged_api",
