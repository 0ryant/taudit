        }
      ]
    },
    "nodeKindEnum": {
      "enum": [
        "step",
        "secret",
        "artifact",
        "identity",
        "image"
      ],
      "type": "string"
    },
    "nodeMatcher": {
      "additionalProperties": false,
      "properties": {
        "metadata": {
          "$ref": "#/$defs/metadataMatcher"
        },
        "node_type": {
          "$ref": "#/$defs/nodeTypeOrList"
        },
        "not": {
          "$ref": "#/$defs/nodeMatcher"
        },
        "trust_zone": {
          "$ref": "#/$defs/trustZoneOrList"
        }
      },
      "type": "object"
    },
    "nodeTypeOrList": {
      "oneOf": [
        {
          "$ref": "#/$defs/nodeKindEnum"
        },
        {
          "items": {
            "$ref": "#/$defs/nodeKindEnum"
          },
          "minItems": 1,
          "type": "array"
        }
      ]
    },
    "pathMatcher": {
      "additionalProperties": false,
      "properties": {
        "crosses_to": {
          "items": {
            "$ref": "#/$defs/trustZoneEnum"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "severity": {
      "enum": [
        "critical",
        "high",
        "medium",
        "low",
        "info"
      ],
      "type": "string"
    },
    "trustZoneEnum": {
      "enum": [
        "first_party",
        "third_party",
        "untrusted"
      ],
      "type": "string"
    },
    "trustZoneOrList": {
      "oneOf": [
        {
          "$ref": "#/$defs/trustZoneEnum"
        },
        {
          "items": {
            "$ref": "#/$defs/trustZoneEnum"
          },
          "minItems": 1,
          "type": "array"
        }
      ]
    }
