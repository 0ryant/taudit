  "$id": "https://taudit.dev/schemas/authority-invariant-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Invariant documents loaded via --invariants-dir / --rules-dir. Matches serde deserialization in crates/taudit-core/src/custom_rules.rs. Regenerate this file with scripts/generate-authority-invariant-schema.py --write.",
  "properties": {
    "category": {
      "$ref": "#/$defs/findingCategory"
    },
    "description": {
      "type": "string"
    },
    "id": {
      "minLength": 1,
      "type": "string"
    },
    "match": {
      "$ref": "#/$defs/matchSpec"
    },
    "name": {
      "minLength": 1,
      "type": "string"
    },
    "severity": {
      "$ref": "#/$defs/severity"
    }
  },
  "required": [
    "id",
    "name",
    "severity",
    "category"
  ],
  "title": "taudit authority invariant (custom invariant YAML) v1",
  "type": "object"
